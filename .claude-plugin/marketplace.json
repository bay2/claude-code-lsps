        "name": "Piebald LLC",
        "email": "support@piebald.ai"
      },
      "lspServers": {
        "typescript": {
          "command": "vtsls",
          "args": [
            "--stdio"
          ],
          "transport": "stdio",
          "extensionToLanguage": {
            ".cjs": "javascript",
            ".js": "javascript",
            ".jsx": "javascriptreact",
            ".mjs": "javascript",
